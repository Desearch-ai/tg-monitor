# =============================================
# Telegram User API (https://my.telegram.org/apps)
# =============================================
TG_API_ID=123456
TG_API_HASH=abcdef1234567890abcdef1234567890

# =============================================
# შენი ტელეფონის ნომერი (საერთაშორისო ფორმატი)
# =============================================
TG_PHONE=+995599123456

# =============================================
# ბოტის ტოკენი (@BotFather-ისგან)
# =============================================
TG_BOT_TOKEN=1234567890:ABCDefGhIjKlMnOpQrStUvWxYz

# =============================================
# შენი Telegram User ID (რომ ბოტმა შენ გამოგიგზავნოს)
# გაარკვე: დაუწერე @userinfobot ტელეგრამში
# =============================================
TG_MY_USER_ID=123456789

# =============================================
# ჯგუფები რომლებსაც ვადევნებთ თვალი
# მძიმით გამოყოფილი username-ები ან chat_id-ები
# =============================================
TG_WATCH_GROUPS=groupname1,groupname2,-1001234567890

# =============================================
# სად გავგზავნოთ სამარი (ჯგუფი ან username)
# =============================================
TG_TARGET_CHAT=@mytargetgroup

# =============================================
# Claude API Key (https://console.anthropic.com)
# =============================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================
# რამდენ წუთში ერთხელ (default: 30)
# =============================================
MONITOR_INTERVAL_MINUTES=30
